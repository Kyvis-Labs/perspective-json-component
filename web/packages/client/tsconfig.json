{
    "compileOnSave": false,
    "compilerOptions": {
        "allowJs": false,
        "allowSyntheticDefaultImports": true,
        "baseUrl": ".",
        "paths": {
            "*": ["*"]
        },
        "declaration": true,
        "declarationDir": "dist/typings/",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "jsx": "react",
        "module": "commonjs",
        "noEmitOnError": true,
        "noImplicitThis": true,
        "noImplicitReturns": false,
        "noImplicitAny": true,
        "suppressImplicitAnyIndexErrors": true,
        "skipLibCheck": true,
        "ignoreDeprecations": "5.0",
        "noUnusedLocals": false,
        "outDir": "dist/",
        "pretty": true,
        "preserveConstEnums": true,
        "sourceMap": true,
        "strictNullChecks": true,
        "target": "es6",
        "lib": ["es6", "dom", "es7", "es2017"],
        "types": ["react", "react-dom"]
    },
    "include": [
        "./typescript/**/*.ts",
        "./typescript/**/*.tsx"
    ],
    "exclude": [
        "node_modules",
        "build"
    ]
}
